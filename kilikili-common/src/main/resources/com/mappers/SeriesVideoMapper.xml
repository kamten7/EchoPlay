<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.kilikili.mappers.SeriesVideoMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.kilikili.entity.po.SeriesVideo">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="series_id" property="seriesId" jdbcType="VARCHAR"/>
        <result column="video_id" property="videoId" jdbcType="VARCHAR"/>
        <result column="sort" property="sort" jdbcType="INTEGER"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
        <result column="is_deleted" property="isDeleted" jdbcType="TINYINT"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, series_id, video_id, sort, create_time, update_time, is_deleted
    </sql>

    <!-- 插入系列视频关联 -->
    <insert id="insert" parameterType="com.kilikili.entity.po.SeriesVideo">
        INSERT INTO kilikili_series_video (
            series_id, video_id, sort
        ) VALUES (
            #{seriesId}, #{videoId}, #{sort}
        )
    </insert>

    <!-- 根据系列ID删除(逻辑删除) -->
    <update id="deleteBySeriesId">
        UPDATE kilikili_series_video SET is_deleted = 1 WHERE series_id = #{seriesId}
    </update>

    <!-- 根据系列ID和视频ID删除(逻辑删除) -->
    <update id="deleteBySeriesVideo">
        UPDATE kilikili_series_video SET is_deleted = 1 WHERE series_id = #{seriesId} AND video_id = #{videoId}
    </update>

    <!-- 动态WHERE条件 -->
    <sql id="Where_Condition">
        <where>
            <if test="query.seriesId != null and query.seriesId != ''">AND series_id = #{query.seriesId}</if>
            <if test="query.videoId != null and query.videoId != ''">AND video_id = #{query.videoId}</if>
        </where>
    </sql>

    <!-- 根据条件查询列表 -->
    <select id="selectListByCondition" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM kilikili_series_video
        <include refid="Where_Condition"/>
        <choose>
            <when test="query.orderBy != null and query.orderBy != ''">
                ORDER BY ${query.orderBy} ${query.orderDirection}
            </when>
            <otherwise>
                ORDER BY sort ASC
            </otherwise>
        </choose>
        <if test="query.pageNo != null and query.pageSize != null">
            LIMIT #{query.pageSize} OFFSET #{query.startIndex}
        </if>
    </select>

    <!-- 根据条件查询数量 -->
    <select id="selectCountByCondition" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM kilikili_series_video
        <include refid="Where_Condition"/>
    </select>

    <!-- 批量插入系列视频关联 -->
    <insert id="insertBatch">
        INSERT INTO kilikili_series_video (
            series_id, video_id, sort
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
                #{item.seriesId}, #{item.videoId}, #{item.sort}
            )
        </foreach>
    </insert>

</mapper>
