{
  "Frontloom: Astro Component": {
    "scope": "astro",
    "prefix": "fl-component",
    "description": "Frontloom Astro component with typed props",
    "body": [
      "---",
      "interface Props {",
      "  ${1:title}: ${2:string};",
      "}",
      "",
      "const { ${1:title} } = Astro.props;",
      "---",
      "",
      "<${3:div}>${0}</${3:div}>"
    ]
  },
  "Frontloom: Astro Layout": {
    "scope": "astro",
    "prefix": "fl-layout",
    "description": "Frontloom Astro layout with SEO",
    "body": [
      "---",
      "import { ViewTransitions } from \"astro:transitions\";",
      "",
      "interface Props {",
      "  title: string;",
      "  description: string;",
      "}",
      "",
      "const { title, description } = Astro.props;",
      "const canonicalUrl = new URL(Astro.url.pathname, Astro.site);",
      "---",
      "",
      "<html lang=\"en\">",
      "  <head>",
      "    <meta charset=\"utf-8\" />",
      "    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />",
      "    <title>{title}</title>",
      "    <meta name=\"description\" content={description} />",
      "    <link rel=\"canonical\" href={canonicalUrl} />",
      "    <meta property=\"og:title\" content={title} />",
      "    <meta property=\"og:description\" content={description} />",
      "    <ViewTransitions />",
      "  </head>",
      "  <body>",
      "    <slot />",
      "  </body>",
      "</html>"
    ]
  },
  "Frontloom: Astro Island": {
    "scope": "astro",
    "prefix": "fl-island",
    "description": "Frontloom Astro framework island with client directive",
    "body": [
      "---",
      "import ${1:Component} from \"../components/${1:Component}\";",
      "---",
      "",
      "<${1:Component} client:${2|load,idle,visible,media,only|} ${0} />"
    ]
  },
  "Frontloom: Astro Collection Page": {
    "scope": "astro",
    "prefix": "fl-collection",
    "description": "Frontloom Astro dynamic page from content collection",
    "body": [
      "---",
      "import { getCollection, render } from \"astro:content\";",
      "",
      "export async function getStaticPaths() {",
      "  const ${1:posts} = await getCollection(\"${2:blog}\");",
      "  return ${1:posts}.map((${3:post}) => ({",
      "    params: { slug: ${3:post}.id },",
      "    props: { ${3:post} },",
      "  }));",
      "}",
      "",
      "const { ${3:post} } = Astro.props;",
      "const { Content } = await render(${3:post});",
      "---",
      "",
      "<article>",
      "  <h1>{${3:post}.data.title}</h1>",
      "  <Content />",
      "</article>"
    ]
  },
  "Frontloom: Astro Content Config": {
    "scope": "typescript",
    "prefix": "fl-content-config",
    "description": "Frontloom Astro content collection config",
    "body": [
      "import { defineCollection, z } from \"astro:content\";",
      "import { glob } from \"astro/loaders\";",
      "",
      "const ${1:blog} = defineCollection({",
      "  loader: glob({ pattern: \"**/*.{md,mdx}\", base: \"./src/data/${1:blog}\" }),",
      "  schema: z.object({",
      "    title: z.string(),",
      "    description: z.string(),",
      "    publishedAt: z.coerce.date(),",
      "    draft: z.boolean().default(false),",
      "    ${0}",
      "  }),",
      "});",
      "",
      "export const collections = { ${1:blog} };"
    ]
  }
}
