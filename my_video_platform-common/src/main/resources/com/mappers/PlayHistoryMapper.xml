<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.myvideoplatform.mappers.PlayHistoryMapper">

    <!-- з»“жһңжҳ е°„ -->
    <resultMap id="BaseResultMap" type="com.myvideoplatform.entity.po.PlayHistory">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="VARCHAR"/>
        <result column="video_id" property="videoId" jdbcType="VARCHAR"/>
        <result column="file_id" property="fileId" jdbcType="VARCHAR"/>
        <result column="progress" property="progress" jdbcType="INTEGER"/>
        <result column="duration" property="duration" jdbcType="INTEGER"/>
        <result column="last_play_time" property="lastPlayTime" jdbcType="TIMESTAMP"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
        <result column="is_deleted" property="isDeleted" jdbcType="TINYINT"/>
    </resultMap>

    <!-- еҹәзЎҖеҲ?-->
    <sql id="Base_Column_List">
        id, user_id, video_id, file_id, progress, duration,
        last_play_time, create_time, update_time, is_deleted
    </sql>

    <!-- жҸ’е…Ҙж’ӯж”ҫеҺҶеҸІ -->
    <insert id="insert" parameterType="com.myvideoplatform.entity.po.PlayHistory">
        INSERT INTO mvp_play_history (
            user_id, video_id, file_id, progress, duration, last_play_time
        ) VALUES (
            #{userId}, #{videoId}, #{fileId}, #{progress}, #{duration}, #{lastPlayTime}
        )
    </insert>

    <!-- ж №жҚ®з”ЁжҲ·IDе’Ңи§Ҷйў‘IDеҲ йҷӨ(йҖ»иҫ‘еҲ йҷӨ) -->
    <update id="deleteByUserIdVideoId">
        UPDATE mvp_play_history SET is_deleted = 1 WHERE user_id = #{userId} AND video_id = #{videoId}
    </update>

    <!-- ж №жҚ®з”ЁжҲ·IDеҲ йҷӨ(йҖ»иҫ‘еҲ йҷӨ) -->
    <update id="deleteByUserId">
        UPDATE mvp_play_history SET is_deleted = 1 WHERE user_id = #{userId}
    </update>

    <!-- ж №жҚ®з”ЁжҲ·IDе’Ңи§Ҷйў‘IDжӣҙж–° -->
    <update id="updateByUserIdVideoId" parameterType="com.myvideoplatform.entity.po.PlayHistory">
        UPDATE mvp_play_history
        <set>
            <if test="fileId != null">file_id = #{fileId},</if>
            <if test="progress != null">progress = #{progress},</if>
            <if test="duration != null">duration = #{duration},</if>
            <if test="lastPlayTime != null">last_play_time = #{lastPlayTime},</if>
        </set>
        WHERE user_id = #{userId} AND video_id = #{videoId}
    </update>

    <!-- ж №жҚ®з”ЁжҲ·IDе’Ңи§Ҷйў‘IDжҹҘиҜў -->
    <select id="selectByUserIdVideoId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mvp_play_history
        WHERE user_id = #{userId} AND video_id = #{videoId} AND is_deleted = 0
    </select>

    <!-- еҠЁжҖҒWHEREжқЎд»¶ -->
    <sql id="Where_Condition">
        <where>
            <if test="query.userId != null and query.userId != ''">AND user_id = #{query.userId}</if>
            <if test="query.videoId != null and query.videoId != ''">AND video_id = #{query.videoId}</if>
            <if test="query.lastPlayTimeStart != null">AND last_play_time &gt;= #{query.lastPlayTimeStart}</if>
            <if test="query.lastPlayTimeEnd != null">AND last_play_time &lt;= #{query.lastPlayTimeEnd}</if>
        </where>
    </sql>

    <!-- ж №жҚ®жқЎд»¶жҹҘиҜўеҲ—иЎЁ -->
    <select id="selectListByCondition" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mvp_play_history
        <include refid="Where_Condition"/>
        <choose>
            <when test="query.orderBy != null and query.orderBy != ''">
                ORDER BY ${query.orderBy} ${query.orderDirection}
            </when>
            <otherwise>
                ORDER BY last_play_time DESC
            </otherwise>
        </choose>
        <if test="query.pageNo != null and query.pageSize != null">
            LIMIT #{query.pageSize} OFFSET #{query.startIndex}
        </if>
    </select>

    <!-- ж №жҚ®жқЎд»¶жҹҘиҜўж•°йҮҸ -->
    <select id="selectCountByCondition" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM mvp_play_history
        <include refid="Where_Condition"/>
    </select>

    <!-- жү№йҮҸжҸ’е…Ҙж’ӯж”ҫеҺҶеҸІ -->
    <insert id="insertBatch">
        INSERT INTO mvp_play_history (
            user_id, video_id, file_id, progress, duration, last_play_time
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
                #{item.userId}, #{item.videoId}, #{item.fileId}, #{item.progress},
                #{item.duration}, #{item.lastPlayTime}
            )
        </foreach>
    </insert>

</mapper>
