<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.myvideoplatform.mappers.DanmuMapper">

    <!-- з»“жһңжҳ е°„ -->
    <resultMap id="BaseResultMap" type="com.myvideoplatform.entity.po.Danmu">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="danmu_id" property="danmuId" jdbcType="VARCHAR"/>
        <result column="video_id" property="videoId" jdbcType="VARCHAR"/>
        <result column="file_id" property="fileId" jdbcType="VARCHAR"/>
        <result column="user_id" property="userId" jdbcType="VARCHAR"/>
        <result column="content" property="content" jdbcType="VARCHAR"/>
        <result column="time_point" property="timePoint" jdbcType="INTEGER"/>
        <result column="mode" property="mode" jdbcType="INTEGER"/>
        <result column="color" property="color" jdbcType="VARCHAR"/>
        <result column="font_size" property="fontSize" jdbcType="INTEGER"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
        <result column="is_deleted" property="isDeleted" jdbcType="TINYINT"/>
    </resultMap>

    <!-- еҹәзЎҖеҲ?-->
    <sql id="Base_Column_List">
        id, danmu_id, video_id, file_id, user_id, content, time_point, mode,
        color, font_size, create_time, update_time, is_deleted
    </sql>

    <!-- жҸ’е…Ҙеј№е№• -->
    <insert id="insert" parameterType="com.myvideoplatform.entity.po.Danmu">
        INSERT INTO mvp_danmu (
            danmu_id, video_id, file_id, user_id, content, time_point, mode, color, font_size
        ) VALUES (
            #{danmuId}, #{videoId}, #{fileId}, #{userId}, #{content}, #{timePoint}, #{mode}, #{color}, #{fontSize}
        )
    </insert>

    <!-- ж №жҚ®еј№е№•IDеҲ йҷӨ(зЎ¬еҲ йҷ? -->
    <delete id="deleteByDanmuId">
        DELETE FROM mvp_danmu WHERE danmu_id = #{danmuId}
    </delete>

    <!-- ж №жҚ®еј№е№•IDжӣҙж–° -->
    <update id="updateByDanmuId" parameterType="com.myvideoplatform.entity.po.Danmu">
        UPDATE mvp_danmu
        <set>
            <if test="videoId != null">video_id = #{videoId},</if>
            <if test="fileId != null">file_id = #{fileId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="content != null">content = #{content},</if>
            <if test="timePoint != null">time_point = #{timePoint},</if>
            <if test="mode != null">mode = #{mode},</if>
            <if test="color != null">color = #{color},</if>
            <if test="fontSize != null">font_size = #{fontSize},</if>
        </set>
        WHERE danmu_id = #{danmuId}
    </update>

    <!-- ж №жҚ®еј№е№•IDжҹҘиҜў -->
    <select id="selectByDanmuId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mvp_danmu
        WHERE danmu_id = #{danmuId} AND is_deleted = 0
    </select>

    <!-- ж №жҚ®и§Ҷйў‘IDжҹҘиҜўеҲ—иЎЁ -->
    <select id="selectByVideoId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mvp_danmu
        WHERE video_id = #{videoId} AND is_deleted = 0
        ORDER BY time_point ASC
    </select>

    <!-- ж №жҚ®ж–Үд»¶IDжҹҘиҜўеҲ—иЎЁ -->
    <select id="selectByFileId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mvp_danmu
        WHERE file_id = #{fileId} AND is_deleted = 0
        ORDER BY time_point ASC
    </select>

    <!-- жҹҘиҜўжүҖжңүеј№е№?-->
    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mvp_danmu
        WHERE is_deleted = 0
        ORDER BY create_time DESC
    </select>

    <!-- еҠЁжҖҒWHEREжқЎд»¶ -->
    <sql id="Where_Condition">
        <where>
            <if test="query.danmuId != null and query.danmuId != ''">AND danmu_id = #{query.danmuId}</if>
            <if test="query.videoId != null and query.videoId != ''">AND video_id = #{query.videoId}</if>
            <if test="query.fileId != null and query.fileId != ''">AND file_id = #{query.fileId}</if>
            <if test="query.userId != null and query.userId != ''">AND user_id = #{query.userId}</if>
            <if test="query.timePointStart != null">AND time_point &gt;= #{query.timePointStart}</if>
            <if test="query.timePointEnd != null">AND time_point &lt;= #{query.timePointEnd}</if>
            <if test="query.textFuzzy != null and query.textFuzzy != ''">AND content LIKE CONCAT('%', #{query.textFuzzy}, '%')</if>
        </where>
    </sql>

    <!-- ж №жҚ®жқЎд»¶жҹҘиҜўеҲ—иЎЁ -->
    <select id="selectListByCondition" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mvp_danmu
        <include refid="Where_Condition"/>
        <choose>
            <when test="query.orderBy != null and query.orderBy != ''">
                ORDER BY ${query.orderBy} ${query.orderDirection}
            </when>
            <otherwise>
                ORDER BY time_point ASC
            </otherwise>
        </choose>
        <if test="query.pageNo != null and query.pageSize != null">
            LIMIT #{query.pageSize} OFFSET #{query.startIndex}
        </if>
    </select>

    <!-- ж №жҚ®жқЎд»¶жҹҘиҜўж•°йҮҸ -->
    <select id="selectCountByCondition" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM mvp_danmu
        <include refid="Where_Condition"/>
    </select>

</mapper>
