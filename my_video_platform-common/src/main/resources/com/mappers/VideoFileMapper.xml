<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis://DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.myvideoplatform.mappers.VideoFileMapper">

    <!-- з»“жһңжҳ е°„ -->
    <resultMap id="BaseResultMap" type="com.myvideoplatform.entity.po.VideoFile">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="file_id" property="fileId" jdbcType="VARCHAR"/>
        <result column="user_id" property="userId" jdbcType="VARCHAR"/>
        <result column="file_name" property="fileName" jdbcType="VARCHAR"/>
        <result column="file_size" property="fileSize" jdbcType="BIGINT"/>
        <result column="file_path" property="filePath" jdbcType="VARCHAR"/>
        <result column="file_suffix" property="fileSuffix" jdbcType="VARCHAR"/>
        <result column="md5" property="md5" jdbcType="VARCHAR"/>
        <result column="chunk_count" property="chunkCount" jdbcType="INTEGER"/>
        <result column="chunk_size" property="chunkSize" jdbcType="BIGINT"/>
        <result column="upload_id" property="uploadId" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="INTEGER"/>
        <result column="duration" property="duration" jdbcType="INTEGER"/>
        <result column="video_cover" property="videoCover" jdbcType="VARCHAR"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
        <result column="is_deleted" property="isDeleted" jdbcType="TINYINT"/>
    </resultMap>

    <!-- еҹәзЎҖеҲ?-->
    <sql id="Base_Column_List">
        id, file_id, user_id, file_name, file_size, file_path, file_suffix, md5,
        chunk_count, chunk_size, upload_id, status, duration, video_cover, create_time, update_time, is_deleted
    </sql>

    <!-- жҸ’е…Ҙи§Ҷйў‘ж–Үд»¶ -->
    <insert id="insert" parameterType="com.myvideoplatform.entity.po.VideoFile">
        INSERT INTO mvp_video_file (
            file_id, user_id, file_name, file_size, file_path, file_suffix, md5,
            chunk_count, chunk_size, upload_id, status, duration, video_cover
        ) VALUES (
            #{fileId}, #{userId}, #{fileName}, #{fileSize}, #{filePath}, #{fileSuffix}, #{md5},
            #{chunkCount}, #{chunkSize}, #{uploadId}, #{status}, #{duration}, #{videoCover}
        )
    </insert>

    <!-- ж №жҚ®ж–Үд»¶IDеҲ йҷӨ(йҖ»иҫ‘еҲ йҷӨ) -->
    <update id="deleteByFileId">
        UPDATE mvp_video_file SET is_deleted = 1 WHERE file_id = #{fileId}
    </update>

    <!-- ж №жҚ®дёҠдј IDеҲ йҷӨ(йҖ»иҫ‘еҲ йҷӨ) -->
    <update id="deleteByUploadId">
        UPDATE mvp_video_file SET is_deleted = 1 WHERE upload_id = #{uploadId}
    </update>

    <!-- ж №жҚ®ж–Үд»¶IDжӣҙж–° -->
    <update id="updateByFileId" parameterType="com.myvideoplatform.entity.po.VideoFile">
        UPDATE mvp_video_file
        <set>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="fileSize != null">file_size = #{fileSize},</if>
            <if test="filePath != null">file_path = #{filePath},</if>
            <if test="fileSuffix != null">file_suffix = #{fileSuffix},</if>
            <if test="md5 != null">md5 = #{md5},</if>
            <if test="chunkCount != null">chunk_count = #{chunkCount},</if>
            <if test="chunkSize != null">chunk_size = #{chunkSize},</if>
            <if test="uploadId != null">upload_id = #{uploadId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="duration != null">duration = #{duration},</if>
            <if test="videoCover != null">video_cover = #{videoCover},</if>
        </set>
        WHERE file_id = #{fileId}
    </update>

    <!-- ж №жҚ®дёҠдј IDжӣҙж–° -->
    <update id="updateByUploadId" parameterType="com.myvideoplatform.entity.po.VideoFile">
        UPDATE mvp_video_file
        <set>
            <if test="fileId != null">file_id = #{fileId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="fileSize != null">file_size = #{fileSize},</if>
            <if test="filePath != null">file_path = #{filePath},</if>
            <if test="fileSuffix != null">file_suffix = #{fileSuffix},</if>
            <if test="md5 != null">md5 = #{md5},</if>
            <if test="chunkCount != null">chunk_count = #{chunkCount},</if>
            <if test="chunkSize != null">chunk_size = #{chunkSize},</if>
            <if test="status != null">status = #{status},</if>
            <if test="duration != null">duration = #{duration},</if>
        </set>
        WHERE upload_id = #{uploadId}
    </update>

    <!-- ж №жҚ®ж–Үд»¶IDжҹҘиҜў -->
    <select id="selectByFileId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mvp_video_file
        WHERE file_id = #{fileId} AND is_deleted = 0
    </select>

    <!-- ж №жҚ®дёҠдј IDжҹҘиҜў -->
    <select id="selectByUploadId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mvp_video_file
        WHERE upload_id = #{uploadId} AND is_deleted = 0
    </select>

    <!-- жҹҘиҜўжүҖжңүи§Ҷйў‘ж–Үд»?-->
    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mvp_video_file
        WHERE is_deleted = 0
        ORDER BY create_time DESC
    </select>

    <!-- еҠЁжҖҒWHEREжқЎд»¶ -->
    <sql id="Where_Condition">
        <where>
            <if test="query.fileId != null and query.fileId != ''">AND file_id = #{query.fileId}</if>
            <if test="query.uploadId != null and query.uploadId != ''">AND upload_id = #{query.uploadId}</if>
            <if test="query.userId != null and query.userId != ''">AND user_id = #{query.userId}</if>
            <if test="query.status != null">AND status = #{query.status}</if>
        </where>
    </sql>

    <!-- ж №жҚ®жқЎд»¶жҹҘиҜўеҲ—иЎЁ -->
    <select id="selectListByCondition" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mvp_video_file
        <include refid="Where_Condition"/>
        <choose>
            <when test="query.orderBy != null and query.orderBy != ''">
                ORDER BY ${query.orderBy} ${query.orderDirection}
            </when>
            <otherwise>
                ORDER BY create_time DESC
            </otherwise>
        </choose>
        <if test="query.pageNo != null and query.pageSize != null">
            LIMIT #{query.pageSize} OFFSET #{query.startIndex}
        </if>
    </select>

    <!-- ж №жҚ®жқЎд»¶жҹҘиҜўж•°йҮҸ -->
    <select id="selectCountByCondition" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM mvp_video_file
        <include refid="Where_Condition"/>
    </select>

</mapper>
