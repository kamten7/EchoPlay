# ============================================
# My Video Platform - 环境变量配置
# ============================================
# 使用说明：
# 1. 复制此文件为 .env 文件：copy .env.example .env
# 2. 修改 .env 中的值为你自己的配置
# 3. Docker Compose 会自动加载 .env 文件
# 4. 不要将 .env 文件提交到 Git！
# ============================================

# --- 数据库配置 ---
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=my_video_platform
MYSQL_USER=my_video_platform
MYSQL_PASSWORD=your_secure_db_password_here

# --- Redis 配置 ---
REDIS_PASSWORD=your_secure_redis_password_here

# --- MinIO (对象存储) 配置 ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_secure_minio_password_here
MINIO_DEFAULT_BUCKETS=my_video_platform

# --- Spring Boot 应用配置 ---
# 数据库密码（供应用读取）
DB_PASSWORD=${MYSQL_PASSWORD}

# 项目文件存储路径（Windows 路径，Docker 挂载用）
WINDOWS_PROJECT_DIR=D:/webser/my_video_platform
WINDOWS_FFMPEG_PATH=C:/Program Files/ffmpeg/bin/ffmpeg.exe

# 日志级别
LOG_LEVEL=debug

# --- 管理员账号 ---
ADMIN_ACCOUNT=admin
ADMIN_PASSWORD=admin123

# --- 阿里云 OSS 配置（按需启用）---
# OSS_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
# OSS_ACCESS_KEY_ID=your-oss-access-key-id
# OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
# OSS_BUCKET_NAME=your-bucket-name

# --- MinIO 端点 ---
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_NAME=my_video_platform