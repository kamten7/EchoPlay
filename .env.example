# ============================================
# EchoPlay - 环境变量配置模板
# ============================================
# 使用说明：
#   1. 复制此文件为 .env：  copy .env.example .env
#   2. 修改 .env 中的值为你自己的配置
#   3. ⚠️ 不要将 .env 文件提交到 Git！
#
# 两种启动方式：
#   【开发模式 - 推荐日常使用】
#      docker compose -f docker-compose.dev.yml up -d
#     → 只启动 MySQL + Redis + MinIO，然后从 IDE 直接运行 Spring Boot
#     → application.yml 默认连接 localhost，无需额外配置环境变量
#
#   【完整模式 - 生产部署】
#      docker compose up -d
#     → 启动所有服务（中间件 + Web 端 + Admin 端），全部容器化运行
#     → 需要先 mvn clean package -DskipTests 打好 jar 包
# ============================================

# ==================== MySQL 配置 ====================
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=echoplay
MYSQL_USER=root
MYSQL_PASSWORD=your_secure_db_password_here

# ==================== 应用数据库连接 ====================
# 与上面 MYSQL_PASSWORD 保持一致即可
DB_PASSWORD=your_secure_db_password_here

# ==================== Redis 配置 ====================
REDIS_PASSWORD=your_secure_redis_password_here

# ==================== MinIO（对象存储）配置 ====================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_secure_minio_password_here
MINIO_BUCKET_NAME=echoplay

# ==================== 阿里云 OSS 配置（可选，按需启用）====================
# 如果不需要 OSS，可以留空或注释掉
OSS_ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_BUCKET=your-bucket-name
OSS_REGION=oss-cn-shenzhen
OSS_PATH_PREFIX=my-video-platform/

# ==================== 项目路径配置 ====================
# 项目文件存储路径（Windows 宿主机路径，Docker 挂载用）
WINDOWS_PROJECT_DIR=D:/webser/echoplay

# FFmpeg 可执行文件完整路径（Spring Boot 应用使用）
# Windows 示例：D:/FFmpeg/ffmpeg-8.1.2-essentials_build/bin/ffmpeg.exe
# Linux/macOS 示例：/usr/bin/ffmpeg
# 留空则自动从系统 PATH 查找
FFMPEG_PATH=

# Windows Docker 环境下 FFmpeg 路径（参考用，实际使用 FFMPEG_PATH）
WINDOWS_FFMPEG_PATH=D:/FFmpeg/ffmpeg-8.1.2-essentials_build/bin/ffmpeg.exe

# 日志级别（debug / info / warn / error）
LOG_LEVEL=info

# ==================== 管理员账号 ====================
ADMIN_ACCOUNT=admin
ADMIN_PASSWORD=your_secure_admin_password_here
