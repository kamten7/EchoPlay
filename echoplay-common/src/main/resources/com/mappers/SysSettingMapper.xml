
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.echoplay.mappers.SysSettingMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.echoplay.entity.po.SysSetting">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="setting_key" property="settingKey" jdbcType="VARCHAR"/>
        <result column="setting_value" property="settingValue" jdbcType="VARCHAR"/>
        <result column="setting_description" property="settingDescription" jdbcType="VARCHAR"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
        <result column="is_deleted" property="isDeleted" jdbcType="TINYINT"/>
    </resultMap>

    <!-- 基础字段列表 -->
    <sql id="Base_Column_List">
        id, setting_key, setting_value, setting_description, create_time, update_time, is_deleted
    </sql>

    <!-- 插入系统设置 -->
    <insert id="insert" parameterType="com.echoplay.entity.po.SysSetting">
        INSERT INTO mvp_sys_setting (
            setting_key, setting_value, setting_description
        ) VALUES (
            #{settingKey}, #{settingValue}, #{settingDescription}
        )
    </insert>

    <!-- 根据设置键更新 -->
    <update id="updateBySettingKey" parameterType="com.echoplay.entity.po.SysSetting">
        UPDATE mvp_sys_setting
        <set>
            <if test="settingValue != null">setting_value = #{settingValue},</if>
            <if test="settingDescription != null">setting_description = #{settingDescription},</if>
        </set>
        WHERE setting_key = #{settingKey}
    </update>

    <!-- 根据设置键查询 -->
    <select id="selectBySettingKey" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mvp_sys_setting
        WHERE setting_key = #{settingKey} AND is_deleted = 0
    </select>

    <!-- 动态WHERE条件 -->
    <sql id="Where_Condition">
        <where>
            <if test="query.settingKey != null and query.settingKey != ''">AND setting_key = #{query.settingKey}</if>
        </where>
    </sql>

    <!-- 根据条件查询列表 -->
    <select id="selectListByCondition" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mvp_sys_setting
        <include refid="Where_Condition"/>
        <choose>
            <when test="query.orderBy != null and query.orderBy != ''">
                ORDER BY ${query.orderBy} ${query.orderDirection}
            </when>
            <otherwise>
                ORDER BY create_time DESC
            </otherwise>
        </choose>
        <if test="query.pageNo != null and query.pageSize != null">
            LIMIT #{query.pageSize} OFFSET #{query.startIndex}
        </if>
    </select>

    <!-- 根据条件查询数量 -->
    <select id="selectCountByCondition" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM mvp_sys_setting
        <include refid="Where_Condition"/>
    </select>

</mapper>
