<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.echoplay.mappers.MessageMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.echoplay.entity.po.Message">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="message_id" property="messageId" jdbcType="VARCHAR"/>
        <result column="receive_user_id" property="receiveUserId" jdbcType="VARCHAR"/>
        <result column="send_user_id" property="sendUserId" jdbcType="VARCHAR"/>
        <result column="message_type" property="messageType" jdbcType="TINYINT"/>
        <result column="content" property="content" jdbcType="VARCHAR"/>
        <result column="related_id" property="relatedId" jdbcType="VARCHAR"/>
        <result column="is_read" property="isRead" jdbcType="TINYINT"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
        <result column="is_deleted" property="isDeleted" jdbcType="TINYINT"/>
    </resultMap>

    <!-- 基础字段列表 -->
    <sql id="Base_Column_List">
        id, message_id, receive_user_id, send_user_id, message_type, content,
        related_id, is_read, create_time, update_time, is_deleted
    </sql>

    <!-- 插入消息 -->
    <insert id="insert" parameterType="com.echoplay.entity.po.Message">
        INSERT INTO mvp_message (
            message_id, receive_user_id, send_user_id, message_type, content, related_id, is_read
        ) VALUES (
            #{messageId}, #{receiveUserId}, #{sendUserId}, #{messageType}, #{content}, #{relatedId}, #{isRead}
        )
    </insert>

    <!-- 批量插入消息 -->
    <insert id="insertBatch">
        INSERT INTO mvp_message (
            message_id, receive_user_id, send_user_id, message_type, content, related_id, is_read
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
                #{item.messageId}, #{item.receiveUserId}, #{item.sendUserId}, #{item.messageType},
                #{item.content}, #{item.relatedId}, #{item.isRead}
            )
        </foreach>
    </insert>

    <!-- 根据消息ID删除(逻辑删除) -->
    <update id="deleteByMessageId">
        UPDATE mvp_message SET is_deleted = 1 WHERE message_id = #{messageId}
    </update>

    <!-- 根据接收用户ID删除(逻辑删除) -->
    <update id="deleteByReceiveUserId">
        UPDATE mvp_message SET is_deleted = 1 WHERE receive_user_id = #{receiveUserId}
    </update>

    <!-- 根据消息ID更新 -->
    <update id="updateByMessageId" parameterType="com.echoplay.entity.po.Message">
        UPDATE mvp_message
        <set>
            <if test="receiveUserId != null">receive_user_id = #{receiveUserId},</if>
            <if test="sendUserId != null">send_user_id = #{sendUserId},</if>
            <if test="messageType != null">message_type = #{messageType},</if>
            <if test="content != null">content = #{content},</if>
            <if test="relatedId != null">related_id = #{relatedId},</if>
            <if test="isRead != null">is_read = #{isRead},</if>
        </set>
        WHERE message_id = #{messageId}
    </update>

    <!-- 根据消息ID查询 -->
    <select id="selectByMessageId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mvp_message
        WHERE message_id = #{messageId} AND is_deleted = 0
    </select>

    <!-- 查询未读消息数量 -->
    <select id="selectNoReadCount" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM mvp_message
        WHERE receive_user_id = #{receiveUserId} AND is_read = 0 AND is_deleted = 0
    </select>

    <!-- 全部标记为已读 -->
    <update id="readAll">
        UPDATE mvp_message SET is_read = 1 WHERE receive_user_id = #{receiveUserId}
    </update>

    <!-- 动态WHERE条件 -->
    <sql id="Where_Condition">
        <where>
            <if test="query.messageId != null and query.messageId != ''">AND message_id = #{query.messageId}</if>
            <if test="query.receiveUserId != null and query.receiveUserId != ''">AND receive_user_id = #{query.receiveUserId}</if>
            <if test="query.sendUserId != null and query.sendUserId != ''">AND send_user_id = #{query.sendUserId}</if>
            <if test="query.messageType != null">AND message_type = #{query.messageType}</if>
            <if test="query.isRead != null">AND is_read = #{query.isRead}</if>
            <if test="query.createTimeStart != null">AND create_time &gt;= #{query.createTimeStart}</if>
            <if test="query.createTimeEnd != null">AND create_time &lt;= #{query.createTimeEnd}</if>
        </where>
    </sql>

    <!-- 根据条件查询列表 -->
    <select id="selectListByCondition" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM mvp_message
        <include refid="Where_Condition"/>
        <choose>
            <when test="query.orderBy != null and query.orderBy != ''">
                ORDER BY ${query.orderBy} ${query.orderDirection}
            </when>
            <otherwise>
                ORDER BY create_time DESC
            </otherwise>
        </choose>
        <if test="query.pageNo != null and query.pageSize != null">
            LIMIT #{query.pageSize} OFFSET #{query.startIndex}
        </if>
    </select>

    <!-- 根据条件查询数量 -->
    <select id="selectCountByCondition" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM mvp_message
        <include refid="Where_Condition"/>
    </select>

</mapper>